# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'unica_english' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # RNSound references AVAudioSession / AVAudioPlayer but its podspec does not declare
    # AVFoundation, so the app link step misses those symbols. Append after CocoaPods writes xcconfigs.
    support_dir = File.join(installer.sandbox.root, 'Target Support Files', 'Pods-unica_english')
    Dir.glob(File.join(support_dir, '*.xcconfig')).each do |xcconfig_path|
      text = File.read(xcconfig_path)
      next if text.include?('AVFoundation')
      patched = text.gsub(/^OTHER_LDFLAGS = (.+)$/) { "OTHER_LDFLAGS = #{$1} -framework \"AVFoundation\"" }
      File.write(xcconfig_path, patched) if patched != text
    end
  end
end
